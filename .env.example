# Jarvis Brain — 环境变量配置
# 复制此文件为 .env 并填写实际值

# ═══════════════════════════════════════════════════════════
# 必填项
# ═══════════════════════════════════════════════════════════

# 预共享 Token — 客户端连接时必须提供此值
# 生成方式: python -c "import secrets; print(secrets.token_urlsafe(32))"
JARVIS_TOKEN=change-me-to-a-random-string

# Claude API Key — LLM 服务
# 获取: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ElevenLabs API Key — TTS 服务
# 获取: https://elevenlabs.io/
ELEVENLABS_API_KEY=

# ═══════════════════════════════════════════════════════════
# 可选项（有默认值）
# ═══════════════════════════════════════════════════════════

# LLM 模型 (默认: claude-haiku-4-5-20251001)
# 可选: claude-sonnet-4-20250514, claude-opus-4-20250514
# 注意: 更大的模型更慢更贵，语音助手推荐用快模型
LLM_MODEL=claude-haiku-4-5-20251001

# ElevenLabs 语音 ID (默认: 21m00Tcm4TlvDq8ikWAM — Rachel)
# 在 ElevenLabs Dashboard 查看可用语音
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ═══════════════════════════════════════════════════════════
# 部署相关
# ═══════════════════════════════════════════════════════════

# 服务端口 (默认: 8000)
# PORT=8000

# 日志级别 (默认: INFO)
# LOG_LEVEL=INFO
