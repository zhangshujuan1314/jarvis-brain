# Jarvis Brain — 环境变量配置

# ═══════════════════════════════════════════════════════════
# 必填项
# ═══════════════════════════════════════════════════════════

# 预共享 Token — 客户端连接时必须提供此值
JARVIS_TOKEN=change-me-to-a-random-string

# LLM API (mimo-v2.5, OpenAI 兼容)
LLM_API_KEY=your-mimo-api-key
LLM_API_BASE=https://api.xiaomimimo.com/v1
LLM_MODEL=mimo-v2.5

# TTS API (mimo-v2.5-tts, 同一平台)
TTS_API_KEY=your-mimo-api-key
TTS_API_BASE=https://api.xiaomimimo.com/v1
TTS_MODEL=mimo-v2.5-tts
TTS_VOICE=alloy

# ═══════════════════════════════════════════════════════════
# 可选项
# ═══════════════════════════════════════════════════════════

# 如果 TTS_API_KEY 未设置，会自动使用 LLM_API_KEY
# TTS_API_KEY=
